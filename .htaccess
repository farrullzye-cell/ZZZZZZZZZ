# RULLZYE STORE Web Development
RewriteEngine On

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.rullzyestore\.com [NC]
RewriteRule ^(.*)$ https://rullzyestore.com/$1 [L,R=301]

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]

# Block access to admin folder
RewriteRule ^admin/ - [F,L]

# Cache Control
<FilesMatch "\.(ico|pdf|jpg|jpeg|png|gif|js|css|svg|woff|woff2)$">
    Header set Cache-Control "max-age=31536050, public"
</FilesMatch>

# Compress
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Custom 404
ErrorDocument 404 /404.html
